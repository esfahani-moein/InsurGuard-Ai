FROM python:3.13-slim

WORKDIR /app

# Install uv
RUN pip install --no-cache-dir uv

# Copy dependency manifest first (layer caching)
COPY pyproject.toml ./

# Install all dependencies via uv into the system Python
RUN uv pip install --system --no-cache -e .

# Copy source (volume-mounted in dev, but needed for initial build)
COPY app/ ./app/

ENV PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1

EXPOSE 8000

CMD ["uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "8000", "--reload", "--log-level", "info"]
